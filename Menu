-- ===== BOUTONS (visibles) =====
local buttons = {}
local btnData = {
    {name = "ESP Players", y = 50, color = Color3.fromRGB(200, 50, 50)},
    {name = "ESP Weapons", y = 100, color = Color3.fromRGB(50, 200, 50)},
    {name = "Show Distance", y = 150, color = Color3.fromRGB(50, 100, 220)},
    {name = "ESP ALL", y = 200, color = Color3.fromRGB(220, 180, 50)},
}

for _, data in ipairs(btnData) do
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.Position = UDim2.new(0.05, 0, 0, data.y)
    btn.Text = "◻ " .. data.name
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.BackgroundColor3 = Color3.fromRGB(55, 55, 85)
    btn.BorderSizePixel = 1
    btn.BorderColor3 = Color3.fromRGB(130, 130, 180)
    btn.BackgroundTransparency = 0
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 16
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Parent = mainFrame
    btn.ZIndex = 999
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 8)
    btnCorner.Parent = btn
    
    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(80, 80, 120)
    end)
    btn.MouseLeave:Connect(function()
        if btn.Text:sub(1,1) == "☑" then
            btn.BackgroundColor3 = data.color
        else
            btn.BackgroundColor3 = Color3.fromRGB(55, 55, 85)
        end
    end)
    
    buttons[data.name] = {
        button = btn,
        enabled = false,
        color = data.color
    }
end

