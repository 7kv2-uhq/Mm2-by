-- ===== BOUTONS =====
local buttons = {}
local btnData = {
    {name = "ESP Players", y = 48, color = Color3.fromRGB(200, 40, 40)},
    {name = "ESP Weapons", y = 96, color = Color3.fromRGB(40, 200, 40)},
    {name = "Show Distance", y = 144, color = Color3.fromRGB(40, 80, 200)},
    {name = "ESP ALL", y = 192, color = Color3.fromRGB(200, 160, 40)},
}

for _, data in ipairs(btnData) do
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 38)
    btn.Position = UDim2.new(0.05, 0, 0, data.y)
    btn.Text = "◻ " .. data.name
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
    btn.BorderSizePixel = 0
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Parent = mainFrame
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btn
    
    buttons[data.name] = {
        button = btn,
        enabled = false,
        color = data.color
    }
end

