--[[
    🔥 ESP PLAYERS - SOLUTION ULTIME
    Détection par outils + mémorisation
]]

print("   📦 [ESP_PLAYERS] Démarrage...")

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer

local espObjects = {}
local enabled = false
local screenGui = nil

-- MÉMOIRE DES RÔLES (persistant)
local roleMemory = {}

-- COULEURS
local COLORS = {
    Murder = Color3.fromRGB(255, 0, 0),    -- Rouge
    Sherif = Color3.fromRGB(0, 100, 255),  -- Bleu
    Hero = Color3.fromRGB(255, 215, 0),    -- Jaune
    Innocent = Color3.fromRGB(0, 255, 0),  -- Vert
}

-- ===== DÉTECTION DU RÔLE PAR LES OUTILS =====
local function detectRoleByTools(character)
    if not character then return nil end
    
    local hasKnife = false
    local hasGun = false
    
    for _, child in pairs(character:GetDescendants()) do
        if child:IsA("Tool") then
            local name = child.Name:lower()
            if name:find("knife") or name:find("blade") or name:find("dagger") or name:find("couteau") then
                hasKnife = true
            end
            if name:find("gun") or name:find("pistol") or name:find("shooter") or name:find("pistolet") then
                hasGun = true
            end
        end
    end
    
    if hasKnife and not hasGun then
        return "Murder"
    end
    if hasGun then
        return "Sherif"
    end
    return nil
end

-- ===== OBTENIR LE RÔLE (avec mémorisation) =====
local function getPlayerRole(targetPlayer)
    local name = targetPlayer.Name
    
    -- 1. Si déjà en mémoire, on renvoie
    if roleMemory[name] then
        return roleMemory[name]
    end
    
    -- 2. Détection par les outils
    if targetPlayer.Character then
        local role = detectRoleByTools(targetPlayer.Character)
        if role then
            roleMemory[name] = role
            print("   ✅ " .. name .. " → " .. role .. " (détecté par outil)")
            return role
        end
    end
    
    -- 3. Par défaut : Innocent (mais on vérifie les autres joueurs)
    -- Si c'est un joueur sans arme, on le met Innocent
    roleMemory[name] = "Innocent"
    print("   👤 " .. name .. " → Innocent (par défaut)")
    return "Innocent"
end

-- ===== FORCER LA MISE À JOUR DES RÔLES =====
local function updateAllRoles()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local role = detectRoleByTools(p.Character)
            if role then
                roleMemory[p.Name] = role
            end
        end
    end
end

-- ===== QUAND UN JOUEUR CHANGE D'OUTIL =====
local function onToolAdded(player, tool)
    task.wait(0.5) -- Attendre que l'outil soit bien équipé
    local role = detectRoleByTools(player.Character)
    if role then
        roleMemory[player.Name] = role
        print("   🔄 " .. player.Name .. " → " .. role .. " (outil équipé)")
    end
end

-- Détecter les changements d'outils
for _, p in pairs(Players:GetPlayers()) do
    if p.Character then
        p.Character.ChildAdded:Connect(function(child)
            if child:IsA("Tool") then
                onToolAdded(p, child)
            end
        end)
    end
end

Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(function(char)
        char.ChildAdded:Connect(function(child)
            if child:IsA("Tool") then
                task.wait(0.5)
                onToolAdded(p, child)
            end
        end)
    end)
end)

-- ===== MISE À JOUR ESP =====
local function updateESP()
    if not enabled then
        for _, obj in pairs(espObjects) do
            pcall(function() obj:Destroy() end)
        end
        espObjects = {}
        return
    end
    
    if not screenGui then
        screenGui = player.PlayerGui:FindFirstChild("ESPPanel")
        if not screenGui then return end
    end
    
    -- Met à jour les rôles périodiquement
    updateAllRoles()
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("Humanoid") then
            local role = getPlayerRole(p)
            local color = COLORS[role] or COLORS.Innocent
            
            local hasESP = false
            for _, obj in pairs(espObjects) do
                if obj:IsA("Highlight") and obj.Adornee == p.Character then
                    hasESP = true
                    obj.FillColor = color
                    break
                end
            end
            
            if not hasESP then
                local h = Instance.new("Highlight")
                h.Adornee = p.Character
                h.FillColor = color
                h.FillTransparency = 0.35
                h.OutlineColor = Color3.fromRGB(255, 255, 255)
                h.OutlineTransparency = 0.1
                h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                h.Parent = screenGui
                table.insert(espObjects, h)
            end
        end
    end
    
    -- Nettoyage
    for i = #espObjects, 1, -1 do
        local obj = espObjects[i]
        if obj:IsA("Highlight") then
            if not obj.Adornee or not obj.Adornee:FindFirstChild("Humanoid") then
                obj:Destroy()
                table.remove(espObjects, i)
            end
        end
    end
end

-- ===== FONCTIONS PUBLIQUES =====
local function toggle()
    enabled = not enabled
    if not enabled then
        for _, obj in pairs(espObjects) do
            pcall(function() obj:Destroy() end)
        end
        espObjects = {}
    end
    return enabled
end

local function isEnabled()
    return enabled
end

-- ===== BOUCLE =====
RunService.RenderStepped:Connect(updateESP)

-- Met à jour les rôles au démarrage
task.wait(1)
updateAllRoles()

-- ===== STOCKAGE =====
_G.ESP.modules.ESPPlayers = {
    toggle = toggle,
    isEnabled = isEnabled
}

-- ===== CONNEXION AU BOUTON =====
local function connectButton()
    local buttons = _G.ESP and _G.ESP.buttons
    if buttons and buttons["ESP Players"] then
        buttons["ESP Players"].button.MouseButton1Click:Connect(function()
            local state = toggle()
            buttons["ESP Players"].button.Text = (state and "☑ " or "◻ ") .. "ESP Players"
            buttons["ESP Players"].button.BackgroundColor3 = state and buttons["ESP Players"].color or Color3.fromRGB(50, 50, 75)
            print("📌 ESP Players = " .. tostring(state))
        end)
        print("   ✅ [ESP_PLAYERS] Connecté au bouton")
    else
        task.wait(0.5)
        connectButton()
    end
end
connectButton()

print("   ✅ [ESP_PLAYERS] Prêt !")
print("   📌 Détection par outils + mémorisation")
return true
